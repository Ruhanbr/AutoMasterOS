# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=AutoMaster
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_256_BIT_RANDOM_KEY
API_V1_PREFIX=/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://automaster:automaster@localhost:5432/automaster
DATABASE_URL_SYNC=postgresql+psycopg2://automaster:automaster@localhost:5432/automaster
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_TASK_MAX_RETRIES=5
CELERY_TASK_RETRY_BACKOFF=60
CELERY_TASK_RETRY_BACKOFF_MAX=3600
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# ─── SEFAZ ────────────────────────────────────────────────────────────────────
SEFAZ_AMBIENTE=2
SEFAZ_UF=SP
SEFAZ_TIMEOUT=30
SEFAZ_MOCK_ENABLED=true
SEFAZ_WEBSERVICE_URL=https://homologacao.nfe.fazenda.sp.gov.br/ws

# ─── Certificado Digital ──────────────────────────────────────────────────────
CERT_PATH=/certs/certificado.pfx
CERT_PASSWORD=senha_do_certificado

# ─── Fiscal / Tributário ──────────────────────────────────────────────────────
REGIME_TRIBUTARIO=1
CNPJ_EMITENTE=00000000000000
RAZAO_SOCIAL_EMITENTE=OFICINA AGRICOLA LTDA
NOME_FANTASIA_EMITENTE=AutoMaster Oficial
IE_EMITENTE=000000000000
CRT=1

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_PATH=/storage
XML_OUTPUT_PATH=/storage/xml
DANFE_OUTPUT_PATH=/storage/danfe

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true
